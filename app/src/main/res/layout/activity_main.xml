<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_navy"
    android:keepScreenOn="true">

    <!-- ── Háttér SchoolLive logó vízjel ─────────────────────────────────── -->
    <ImageView
        android:id="@+id/ivWatermark"
        android:layout_width="720dp"
        android:layout_height="720dp"
        android:src="@drawable/ic_launcher_foreground"
        android:scaleType="fitCenter"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Narancs csengetés sáv (felül, alapból elrejtve) ───────────────── -->
    <LinearLayout
        android:id="@+id/bellNotificationBar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_bell_notification"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvBellNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 Csengetés folyamatban"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Bal felső: SchoolLive + tenant neve ────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topLeftInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/bellNotificationBar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SchoolLive"
            android:textColor="@color/accent_blue"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tvTenantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="–"
            android:textColor="@color/text_dim"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- ── Jobb felső: státusz indikátorok ───────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/bellNotificationBar"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/indicatorWs"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_circle"
            app:tint="@color/orange_radio" />

        <ImageView
            android:id="@+id/indicatorSnap"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_circle"
            app:tint="@color/red_err" />
    </LinearLayout>

    <!-- ── Fő tartalom: óra + dátum + következő csengetés ───────────────── -->
    <LinearLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Óra (HH:mm:ss) -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/text_primary"
            android:textSize="200sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="-0.03" />

        <!-- Dátum -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_date"
            android:textSize="36sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="4dp" />

        <!-- Következő csengetés pill -->
        <LinearLayout
            android:id="@+id/bellPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_bell_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="22sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvNextBellLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Következő csengetés: "
                android:textColor="@color/text_dim"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tvNextBell"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── TTS üzenet overlay ─────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/overlayMessage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvOverlayMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="48dp"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:fontFamily="sans-serif-light" />

        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_progress" />
    </FrameLayout>

    <!-- ── Rádió overlay ─────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/overlayRadio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_radio_bg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📻"
                android:textSize="64sp" />

            <TextView
                android:id="@+id/tvRadioTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rádió"
                android:textColor="@color/orange_radio"
                android:textSize="28sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <View
            android:id="@+id/viewRadioBar"
            android:layout_width="120dp"
            android:layout_height="4dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="40dp"
            android:background="@color/orange_radio" />
    </FrameLayout>

    <!-- ── Vezérlő panel (tapintásra jelenik meg) ────────────────────────── -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_control_panel"
        android:padding="12dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp">

        <Button
            android:id="@+id/btnVolDown"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="−"
            android:textSize="20sp"
            style="@style/Widget.Material3.Button.IconButton" />

        <TextView
            android:id="@+id/tvVolume"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:text="100%" />

        <Button
            android:id="@+id/btnVolUp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="20sp"
            style="@style/Widget.Material3.Button.IconButton" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>