<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Logó ──────────────────────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="320dp"
        android:layout_height="210dp"
        android:layout_marginTop="32dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Alcím ─────────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Android Player beállítása"
        android:textColor="@color/text_dim"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Elválasztó vonal ───────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#222244"
        android:layout_marginTop="20dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Eszköz azonosító label ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvShortIdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Eszköz azonosítója (aktiváláshoz):"
        android:textColor="@color/text_dim"
        android:textSize="13sp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── AL-XXXX azonosító ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvShortId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AL-0000"
        android:textColor="@color/accent_blue"
        android:textSize="52sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvShortIdLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Státusz szöveg ─────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Csatlakozás…"
        android:textColor="@color/text_dim"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="24dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvShortId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Progress ──────────────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:indeterminateTint="@color/accent_blue"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Újrapróbálás gomb (csak hiba esetén jelenik meg) ───────────────── -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Újrapróbálás"
        android:visibility="gone"
        android:backgroundTint="@color/accent_blue"
        android:textColor="@color/bg_dark"
        android:layout_marginTop="16dp"
        style="@style/Widget.MaterialComponents.Button"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Szerver info alul ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvServerInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="api.schoollive.hu"
        android:textColor="#FF333355"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
